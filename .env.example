# ============================================================
# smart-home-app — Environment Configuration
# Copy this file to .env and fill in all required values.
# NEVER commit the .env file to version control.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
ENVIRONMENT=development
# Options: development | production
LOG_LEVEL=INFO
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL

# ------------------------------------------------------------
# Database (PostgreSQL via asyncpg)
# ------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=smarthome
POSTGRES_USER=smarthome
POSTGRES_PASSWORD=changeme_db_password

# Asyncpg DSN (used by SQLAlchemy + Alembic)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://smarthome:changeme_db_password@db:5432/smarthome

# For Alembic (synchronous psycopg v3, used only during migrations)
# Both postgresql+psycopg:// (v3, preferred) and postgresql+psycopg2:// (legacy) work.
ALEMBIC_DATABASE_URL=postgresql+psycopg://smarthome:changeme_db_password@db:5432/smarthome

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------
# Generate a strong secret with: python scripts/generate_secret.py
SECRET_KEY=CHANGE_ME_generate_with_scripts_generate_secret_py

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------
# FRITZ!Box Provider
# ------------------------------------------------------------
# Set FRITZ_MOCK_MODE=true to use the MockProvider (no hardware required)
FRITZ_MOCK_MODE=true

# FRITZ!Box network address (IP or hostname)
FRITZ_HOST=192.168.178.1

# FRITZ!Box login credentials
FRITZ_USERNAME=admin
FRITZ_PASSWORD=changeme_fritz_password

# Optional: FRITZ!Box SSL certificate verification
FRITZ_SSL_VERIFY=false

# ------------------------------------------------------------
# Weather
# ------------------------------------------------------------
# Provider selection: open-meteo (free, no key) | openweathermap
WEATHER_PROVIDER=open-meteo

# Location for weather queries
WEATHER_LOCATION_LAT=48.1351
WEATHER_LOCATION_LON=11.5820
# Timezone for weather display (e.g. Europe/Berlin)
WEATHER_TIMEZONE=Europe/Berlin

# OpenWeatherMap API key — only required if WEATHER_PROVIDER=openweathermap
# OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# ------------------------------------------------------------
# Admin Seed User (used by seeds/001_admin_user.py)
# ------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password
